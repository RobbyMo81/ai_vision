# LLM Provider: "anthropic" | "openai"
STAGEHAND_LLM_PROVIDER=anthropic

# Anthropic models (pick one):
#   claude-haiku-4-5-20251001   ← fastest / cheapest
#   claude-sonnet-4-6            ← balanced (recommended)
#   claude-opus-4-6              ← most capable / most expensive
STAGEHAND_LLM_MODEL=claude-sonnet-4-6

# OpenAI models (if STAGEHAND_LLM_PROVIDER=openai):
#   gpt-4o-mini   ← cheapest
#   gpt-4o        ← standard
#   o3            ← most capable
# STAGEHAND_LLM_MODEL=gpt-4o-mini

# Optional provider-specific model overrides (recommended when using fallback)
# STAGEHAND_LLM_MODEL_ANTHROPIC=claude-sonnet-4-6
# STAGEHAND_LLM_MODEL_OPENAI=gpt-4o

# Optional fallback provider. If primary provider fails due quota/auth/rate-limit,
# browser-use retries once with this provider (or auto-switches to the other provider).
# STAGEHAND_LLM_FALLBACK_PROVIDER=openai

# Optional local Vault container integration
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_TOKEN=root
# VAULT_SECRET_PATH=secret/data/ai-vision

# API Keys (only the one matching your provider is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Engine server ports (defaults shown)
BROWSER_USE_PORT=8001
SKYVERN_PORT=8002

# Storage
SESSION_DIR=./sessions
DB_PATH=./ai-vision.db

# SIC Memory Policy (FORGE-first)
# true (default behavior): require forge-memory.db for SIC improvements/triggers
# false: allow non-FORGE fallback for local development only
AI_VISION_SIC_FORGE_STRICT=true
# Optional explicit FORGE memory DB location
# FORGE_MEMORY_DB_PATH=./forge-memory.db
