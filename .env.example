# LLM Provider (required by Browser-use and Skyvern)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Engine server ports (defaults shown)
BROWSER_USE_PORT=8001
SKYVERN_PORT=8002

# Stagehand LLM provider: "openai" | "anthropic"
STAGEHAND_LLM_PROVIDER=openai
STAGEHAND_LLM_MODEL=gpt-4o

# Storage
SESSION_DIR=./sessions
DB_PATH=./ai-vision.db
