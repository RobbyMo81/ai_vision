# LLM Provider: "anthropic" | "openai"
STAGEHAND_LLM_PROVIDER=anthropic

# Anthropic models (pick one):
#   claude-haiku-4-5-20251001   ← fastest / cheapest
#   claude-sonnet-4-6            ← balanced (recommended)
#   claude-opus-4-6              ← most capable / most expensive
STAGEHAND_LLM_MODEL=claude-sonnet-4-6

# OpenAI models (if STAGEHAND_LLM_PROVIDER=openai):
#   gpt-4o-mini   ← cheapest
#   gpt-4o        ← standard
#   o3            ← most capable
# STAGEHAND_LLM_MODEL=gpt-4o-mini

# API Keys (only the one matching your provider is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Engine server ports (defaults shown)
BROWSER_USE_PORT=8001
SKYVERN_PORT=8002

# Storage
SESSION_DIR=./sessions
DB_PATH=./ai-vision.db
