{
  "name": "ai-vision",
  "version": "0.1.0",
  "description": "AI-driven browser automation platform with multi-engine support",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "main": "dist/index.js",
  "bin": {
    "ai-vision": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && pnpm run copy-assets",
    "copy-assets": "cp -r src/engines/browser-use/server dist/engines/browser-use/ && cp -r src/engines/skyvern/server dist/engines/skyvern/ && mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "forge": "bash scripts/forge/forge.sh",
    "serve": "node dist/cli/index.js serve",
    "serve:headed": "node dist/cli/index.js serve --headed",
    "vault:up": "docker compose -f docker-compose.vault.yml up -d",
    "vault:down": "docker compose -f docker-compose.vault.yml down",
    "vault:init": "./scripts/secrets/vault-init.sh",
    "vault:export": "./scripts/secrets/vault-export-env.sh",
    "config:build": "cargo build --release --manifest-path tools/config-gui/Cargo.toml",
    "config": "ts-node src/cli/index.ts config",
    "sic:migrate:forge": "ts-node ForgeMP/migrate-sic-to-forge.ts",
    "dev": "ts-node src/index.ts",
    "cli": "ts-node src/cli/index.ts",
    "postinstall": "node -e \"const [major, minor] = process.versions.node.split('.').map(Number); if (major !== 24 || minor < 14) { console.error('Node 24.14.0+ and <25 is required. Run `nvm use`.'); process.exit(1); }\"",
    "test": "node --no-warnings ./node_modules/jest/bin/jest.js --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "js-yaml": "^4.1.1",
    "playwright-core": "^1.40.0",
    "ws": "^8.18.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.0",
    "@types/ws": "^8.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ]
  }
}
